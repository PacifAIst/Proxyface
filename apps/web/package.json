{
  "name": "@proxyface/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync-models": "node scripts/sync-models.mjs",
    "sync-sprites": "node scripts/sync-sprites.mjs",
    "sync-assets": "pnpm sync-models && pnpm sync-sprites",
    "predev": "pnpm sync-assets",
    "prebuild": "pnpm sync-assets",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint placeholder'",
    "clean": "rm -rf dist .turbo *.tsbuildinfo public/models public/sprites"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.0",
    "@mediapipe/tasks-vision": "^0.10.14",
    "@proxyface/core": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
