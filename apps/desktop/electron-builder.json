{
  "appId": "com.pacifaist.proxyface",
  "productName": "ProxyFace",
  "asar": false,
  "directories": {
    "output": "release"
  },
  "files": [
    "electron.cjs",
    "preload.cjs"
  ],
  "extraResources": [
    {
      "from": "../../apps/web/dist",
      "to": "dist",
      "filter": ["**/*"]
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "../../apps/web/public/favicon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
